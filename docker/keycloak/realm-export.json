{
  "realm": "ztforge",
  "enabled": true,
  "displayName": "ZTForge",
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Full system access" },
      { "name": "editor", "description": "Create and edit canvases and policies" },
      { "name": "viewer", "description": "Read-only access to shared canvases" },
      { "name": "guest", "description": "Limited access to public resources" }
    ]
  },
  "defaultRoles": ["viewer"],
  "clients": [
    {
      "clientId": "ztforge-app",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:3000"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "3600",
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@ztforge.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "ZTForge",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "editor",
      "email": "editor@ztforge.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Editor",
      "credentials": [
        {
          "type": "password",
          "value": "editor123",
          "temporary": false
        }
      ],
      "realmRoles": ["editor"]
    },
    {
      "username": "viewer",
      "email": "viewer@ztforge.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Viewer",
      "credentials": [
        {
          "type": "password",
          "value": "viewer123",
          "temporary": false
        }
      ],
      "realmRoles": ["viewer"]
    }
  ]
}
