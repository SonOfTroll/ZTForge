# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=ztforge
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=ztforge
DATABASE_URL=postgresql+asyncpg://ztforge:changeme_in_production@postgres:5432/ztforge

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Keycloak ───────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=ztforge
KEYCLOAK_CLIENT_ID=ztforge-app
KEYCLOAK_CLIENT_SECRET=changeme_in_production
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── Backend ────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=generate-a-real-secret-with-openssl-rand-hex-32
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
RATE_LIMIT_PER_SECOND=10

# ─── OPA ────────────────────────────────────────────────────
OPA_URL=http://opa:8181

# ─── Feature Flags ──────────────────────────────────────────
ENABLE_BREACH_SIMULATION=true
ENABLE_POLICY_HUB=true
ENABLE_ENFORCEMENT_DEMO=false
